    {
      "name": "💬 Legal Chatbot",
      "description": "Lawyer আইনি প্রশ্ন করবেন, AI Bangladesh law অনুযায়ী উত্তর দেবে।\n`chatHistory` array দিলে AI আগের কথোপকথন মনে রাখে।",
      "item": [
        {
          "name": "POST /api/chat/ask — Simple Question",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Chatbot responded', function () {",
                  "    pm.response.to.have.status(200);",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.answer).to.be.a('string');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"চুক্তি ভঙ্গ হলে Bangladesh আইনে কী পদক্ষেপ নেওয়া যায়?\",\n  \"chatHistory\": []\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/chat/ask",
              "host": ["{{baseUrl}}"],
              "path": ["api", "chat", "ask"]
            },
            "description": "একটি simple legal question করো। `chatHistory` empty রাখো।"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"question\": \"চুক্তি ভঙ্গ হলে Bangladesh আইনে কী পদক্ষেপ নেওয়া যায়?\",\n  \"answer\": \"Bangladesh Contract Act 1872 এর Section 73 অনুযায়ী, চুক্তি ভঙ্গ হলে ক্ষতিগ্রস্ত পক্ষ ক্ষতিপূরণ দাবি করতে পারেন...\",\n  \"timestamp\": \"2025-01-15T10:30:00.000Z\"\n}"
            }
          ]
        },
        {
          "name": "POST /api/chat/ask — Multi-turn (chatHistory সহ)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
