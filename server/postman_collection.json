{
  "info": {
    "_postman_id": "9f2c3d2a-5f51-4c6b-9c3e-8b9e54f8b1a0",
    "name": "⚖️ AI Lawyer Assistant API",
    "description": "AI Lawyer Assistant — Lawyer ও Client-দের email conversations DB তে store করে, প্রতি 12 ঘন্টায় AI update পাঠায়, এবং legal chatbot সুবিধা দেয়।\n\n**Base URL:** http://localhost:5000\n\n**Setup:**\n1. `conversationId` variable টি একটি real conversation _id দিয়ে update করো (GET /api/conversations থেকে পাবে)\n2. `clientEmail` variable টি একটি real client email দিয়ে update করো",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "description": "Server base URL"
    },
    {
      "key": "conversationId",
      "value": "",
      "description": "GET /api/conversations থেকে একটি _id copy করে এখানে paste করো"
    },
    {
      "key": "clientEmail",
      "value": "client@gmail.com",
      "description": "Test email পাঠানোর জন্য client-এর email"
    }
  ],
  "item": [
    {
      "name": "🟢 Health Check",
      "description": "Server চলছে কিনা দেখো",
      "item": [
